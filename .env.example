# ─── サーバー設定 ────────────────────────────────────────
PORT=3000

# 外部からアクセスできるURL（末尾スラッシュなし）
# 例: https://hub-mcp.itreat.co.jp または http://192.168.1.100:3000
BASE_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────
# GCP Console → 認証情報 → OAuth 2.0 クライアント ID から取得
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── セキュリティキー ─────────────────────────────────────
# JWTセッション署名キー（任意の長い文字列）
JWT_SECRET=change-me-to-a-long-random-string

# 認証情報暗号化キー（32バイト = 64文字の16進数）
# 生成方法: npm run start で起動時に自動生成してくれます
ENCRYPTION_KEY=your-64-character-hex-string-here

# ─── DBパス（省略時: ./data/hub-mcp.db）────────────────
# DB_PATH=/path/to/hub-mcp.db
