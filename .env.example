# ─── サーバー設定 ────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# ─── Google OAuth（ログイン用） ───────────────────────────
# GCP Console → 認証情報 → OAuth 2.0 クライアントID から取得
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Chatwork OAuth ───────────────────────────────────────
# https://www.chatwork.com/service/packages/chatwork/subpackages/api/oauth_client.php
# リダイレクトURIに {BASE_URL}/oauth/chatwork/callback を登録すること
CHATWORK_CLIENT_ID=your-chatwork-client-id
CHATWORK_CLIENT_SECRET=your-chatwork-client-secret

# ─── Backlog OAuth ────────────────────────────────────────
# Backlog スペース設定 → アプリケーション から取得
# リダイレクトURIに {BASE_URL}/oauth/backlog/callback を登録すること
BACKLOG_CLIENT_ID=your-backlog-client-id
BACKLOG_CLIENT_SECRET=your-backlog-client-secret
# スペースID（例: itreat.backlog.com の場合は「itreat」）
BACKLOG_SPACE=yourspace

# ─── セキュリティキー ─────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=your-64-character-hex-string-here

# ─── DBパス（省略時: ./data/hub-mcp.db）────────────────
# DB_PATH=/path/to/hub-mcp.db
